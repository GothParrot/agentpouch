# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://agentbox:changeme@localhost:5432/agentbox
API_TOKEN=changeme-use-a-long-random-string

# ── Public URL (required for correct human_link generation) ───────────────────
# On self-hosted: set this to your domain, e.g. https://files.example.com
# If unset, falls back to http://localhost:PORT (fine for local dev only)
PUBLIC_BASE_URL=https://your-domain.example.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
# Set to true to run DB migrations automatically on startup (safe, uses advisory lock)
AUTO_MIGRATE=false

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE=local        # local | s3
STORAGE_PATH=/data   # local storage root (ignored when STORAGE=s3)

# S3-compatible storage (required when STORAGE=s3)
# Works with AWS S3, Cloudflare R2, MinIO, Backblaze B2
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # omit for AWS S3
# S3_BUCKET=agentbox
# S3_REGION=us-east-1                                       # R2: auto | B2: region varies
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Guest mode ────────────────────────────────────────────────────────────────
# Allow unauthenticated uploads (no API key required)
ENABLE_GUEST_MODE=false
GUEST_MAX_FILE_SIZE=10485760    # 10 MB — max per guest upload
GUEST_MAX_TTL=1d                # max expiry preset guests may choose

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=107374182400      # 100 GB — server-wide cap
DEFAULT_TTL=7d                  # used when no expires_in specified
ALLOWED_EXPIRY_PRESETS=10m,1d,3d,7d,30d

# ── Short-link domain (optional) ──────────────────────────────────────────────
# If set, requests to this domain are routed to the short-link handler only.
# Useful for vanity domains like files.example.com separate from your API domain.
# SHORTLINK_DOMAIN=files.your-domain.example.com
